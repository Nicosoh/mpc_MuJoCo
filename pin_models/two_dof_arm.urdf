<?xml version="1.0"?>
<robot name="double_pendulum">
  
  <link name="base_link">
    <visual>
      <geometry>
        <sphere radius="0.05"/>
      </geometry>
      <material name="black">
        <color rgba="0 0 0 1"/>
      </material>
    </visual>
  </link>
  
  <link name="link1">
    <inertial>
      <origin xyz="0 0 0.8" rpy="0 0 0"/>
      <mass value="1.0"/> <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.8"/>
      </geometry>
      <material name="white">
        <color rgba="1 1 1 1"/>
      </material>
    </visual>

    <visual>
      <origin xyz="0 0 0.8" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
  </link>
  
  <joint name="pendulum1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <axis xyz="0 1 0"/> 
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
  </joint>

  
  <link name="link2">
    <inertial>
      <origin xyz="0 0 0.8" rpy="0 0 0"/>
      <mass value="1.0"/> <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.004"/>
    </inertial>
    
    <visual>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.01" length="0.8"/>
      </geometry>
      <material name="white"/>
    </visual>

    <visual>
      <origin xyz="0 0 0.8" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.1"/>
      </geometry>
      <material name="red"/>
    </visual>

    <visual>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
      <geometry>
        <capsule radius="0.12" length="0.8"/>
      </geometry>
      <material name="blue_transp">
        <color rgba="0.0 0.5 1.0 0.3"/> 
      </material>
    </visual>
  </link>
  
  <joint name="pendulum2" type="revolute">
    <parent link="link1"/>
    <child link="link2"/>
    <axis xyz="0 1 0"/>
    <origin xyz="0 0 0.8" rpy="0 0 0"/> 
    <limit lower="-3.14" upper="3.14" effort="100" velocity="10"/>
  </joint>

  <link name="ee_link"/>
  <joint name="ee_fixed_joint" type="fixed">
    <parent link="link2"/>
    <child link="ee_link"/>
    <origin xyz="0 0 0.8" rpy="0 0 0"/>
  </joint>

</robot>