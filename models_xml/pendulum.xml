<mujoco model="pendulum">
    
    <!-- Background texture -->
    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3"
        rgb2=".2 .3 .4" width="100" height="100"/>
        <material name="grid" texture="grid" texrepeat="8 8" reflectance=".2"/>
    </asset>

    <worldbody>
        <camera pos="0.005 -3.036 1.691" xyaxes="1.000 0.002 -0.000 -0.000 0.267 0.964"/>
        <!-- Place background -->
        <geom size="2 2 .01" type="plane" material="grid"/>
        <!-- Static light -->
        <light pos="0 0 3" dir="0 0 -1" diffuse=".8 .8 .8" specular=".3 .3 .3"/>

        <!-- Weightless pendulum -->
        <body name="pendulum_stick" pos="0 0 1">
            <joint name="hinge" type="hinge" axis="0 1 0" pos="0 0 0"/>
            <geom name="pendulum_stick_geom" type="capsule" fromto="0 0 0 0 0 0.8" size="0.025"/>
            <inertial mass="0.0001" diaginertia="1e-5 1e-5 1e-5"  pos="0 0 0"/>
            
            <!-- Mass on the end of the pendulum -->
            <body name="pendulum" pos="0 0 0.8">
                <geom name="pendulum_geom" type="sphere" size="0.1"/>
                <inertial mass="0.1" diaginertia="1e-5 1e-5 1e-5" pos="0 0 0"/>
            </body>
        </body>

    </worldbody>
    
    <!-- Force actuator on the cart -->
    <actuator>
        <general joint="hinge"/>
    </actuator>

</mujoco>
