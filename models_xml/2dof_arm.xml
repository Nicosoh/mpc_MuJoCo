<mujoco model="2dof_arm">
    
    <!-- Background texture -->
    <asset>
        <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3"
        rgb2=".2 .3 .4" width="100" height="100"/>
        <material name="grid" texture="grid" texrepeat="8 8" reflectance=".2"/>
    </asset>

    <worldbody>
        <camera pos="0.469 -5.777 0.669" xyaxes="1.000 0.005 -0.000 -0.001 0.157 0.988"/>
        <!-- Place background -->
        <geom size="2 2 .01" pos="0 0 -2" type="plane" material="grid"/>
        <!-- Static light -->
        <light pos="0 0 5" dir="0 0 -1" diffuse=".8 .8 .8" specular=".3 .3 .3"/>

        <!-- Weightless pendulum -->
        <body name="pendulum_stick1" pos="0 0 0">
            <joint name="hinge1" type="hinge" axis="0 1 0" pos="0 0 0"/>
            <geom name="pendulum_stick_geom1" type="capsule" fromto="0 0 0 0 0 0.8" size="0.025"/>
            <inertial mass="0.0001" diaginertia="1e-5 1e-5 1e-5"  pos="0 0 0"/>
            
            <!-- Mass on the end of the pendulum -->
            <body name="pendulum1" pos="0 0 0.8">
                <geom name="pendulum_geom1" type="sphere" size="0.1"/>
                <inertial mass="0.1" diaginertia="2e-3 2e-3 2e-3" pos="0 0 0"/>

                <body name="pendulum_stick2" pos="0 0 0">
                    <joint name="hinge2" type="hinge" axis="0 1 0" pos="0 0 0"/>
                    <geom name="pendulum_stick_geom2" type="capsule" fromto="0 0 0 0 0 0.8" size="0.025"/>
                    <inertial mass="0.0001" diaginertia="1e-5 1e-5 1e-5"  pos="0 0 0"/>

                    <geom name="visual_capsule"
                        type="capsule"
                        fromto="0 0 0 0 0 0.8"
                        size="0.1"
                        rgba="0.2 0.6 1.0 0.3"/>
                    
                    <!-- Mass on the end of the pendulum -->
                    <body name="pendulum2" pos="0 0 0.8">
                        <geom name="pendulum_geom2" type="sphere" size="0.1"/>
                        <inertial mass="0.1" diaginertia="2e-3 2e-3 2e-3" pos="0 0 0"/>
                    </body>
                </body>
            </body>
        </body>

        <!-- Static sphere obstacle -->
        <!-- <body name="sphere_obstacle" pos="1.3 0 0.5">
            <geom name="sphere_geom" type="sphere" size="0.3" rgba="0.8 0.1 0.1 1"/>
            <inertial mass="0" pos="0 0 0"/>
        </body> -->

        <!-- Static sphere obstacle -->
        <body name="capsule_obstacle">
            <geom name="capsule_geom" type="capsule" size="0.1" fromto="1.1 0 0.5 1.1 0 0.8" rgba="0.8 0.1 0.1 1"/>
            <inertial mass="0" pos="0 0 0"/>
        </body>

    </worldbody>
    
    <!-- Force actuator on the cart -->
    <actuator>
        <general joint="hinge1"/>
        <general joint="hinge2"/>
    </actuator>

    <!-- Exclude collisions between 2DOF arm and the static sphere -->
    <contact>
        <exclude body1="pendulum_stick1" body2="capsule_obstacle"/>
        <exclude body1="pendulum1"       body2="capsule_obstacle"/>
        <exclude body1="pendulum_stick2" body2="capsule_obstacle"/>
        <exclude body1="pendulum2"       body2="capsule_obstacle"/>
    </contact>


</mujoco>